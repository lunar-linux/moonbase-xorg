 SOURCE_URL_FULL=https://github.com/intel/libva/archive/refs/tags/$VERSION.tar.gz
      SOURCE_VFY=sha256:b10aceb30e93ddf13b2030eb70079574ba437be9b3b76065caf28a72c07e23e7
        WEB_SITE=http://www.freedesktop.org/wiki/Software/vaapi
         ENTERED=20110211
