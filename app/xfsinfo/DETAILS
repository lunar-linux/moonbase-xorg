          MODULE=xfsinfo
         VERSION=1.0.8
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$XORG_URL/individual/app/
      SOURCE_VFY=sha256:ae80592b6063da928e3d0c81023709b2fa29a04fcda49f6c363ac579d97f23a2
   MODULE_PREFIX=${X11R7_PREFIX:-/usr}
        WEB_SITE=http://www.x.org
         ENTERED=20070216
         UPDATED=20260613
           SHORT="X font server information utility"

cat << EOF
Xfsinfo is a utility for displaying information about an X font server.
It is used to examine the capabilities of a server, the predefined values for
various parameters used in communicating between clients and the server, and
the font catalogues and alternate servers that are available.
EOF
